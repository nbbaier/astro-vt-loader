{
	"name": "astro-vt-loader",
	"version": "0.1.0",
	"description": "An Astro content loader for Val Town vals",
	"type": "module",
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsdown",
		"dev": "tsdown --watch",
		"typecheck": "tsc --noEmit",
		"test": "bun test"
	},
	"keywords": [
		"astro",
		"astro-loader",
		"valtown",
		"val-town",
		"content-loader"
	],
	"license": "MIT",
	"peerDependencies": {
		"astro": "^6.1.1"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.9",
		"@types/bun": "^1.3.11",
		"@types/node": "^25.5.0",
		"tsdown": "^0.22.4",
		"typescript": "^6.0.2"
	},
	"private": true
}
